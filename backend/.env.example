# ============================================================================
# CRM IA ENTERPRISE - ENVIRONMENT VARIABLES
# ============================================================================

# Application
NODE_ENV=development
PORT=3333
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3333
CORS_ORIGIN=http://localhost:5173

# URL pública usada pra registrar webhook na Evolution API
# Em prod: https://crm21go.site
PUBLIC_WEBHOOK_URL=http://localhost:3333

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/crm_db

# Redis (for queues and caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================================================
# INTEGRATIONS
# ============================================================================


# WhatsApp Business API (Meta/Facebook)
# Get token from: https://developers.facebook.com/docs/whatsapp/business-management-api/get-started
WHATSAPP_API_TOKEN=EAAxxxxx...
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_VERIFY_TOKEN=your_random_verify_token

# ============================================================================
# Evolution API (WhatsApp não-oficial via QR — usado em produção 21Go)
# ============================================================================
# Servidor Evolution v2 (auto-hospedado)
EVOLUTION_API_URL=https://evolution.exemplo.com
# API key global do servidor Evolution (admin)
EVOLUTION_API_KEY=your-evolution-global-apikey
# Nome da instância padrão (1 por usuário/vendedor)
EVOLUTION_INSTANCE=21gosite
# Secret HMAC/token compartilhado pra validar requisições do webhook Evolution
# Gere com: openssl rand -hex 32
EVOLUTION_WEBHOOK_SECRET=

# Email SMTP Configuration
# Gmail: Use App Password (https://support.google.com/accounts/answer/185833)
# SendGrid: https://sendgrid.com/docs/for-developers/sending-email/integrations/
# Resend: https://resend.com/docs/send-with-smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# ============================================================================
# AI PROVIDERS (Optional - at least one required for AI features)
# ============================================================================

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Anthropic Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (https://aistudio.google.com/app/apikey)
GOOGLE_AI_API_KEY=AIza...

# ============================================================================
# OpenRouter (usado no /ai/ask do Dashboard — Q&A em linguagem natural com tool use)
# ============================================================================
# Obter chave em: https://openrouter.ai/keys
# Default model: Claude Haiku 4.5 (rápido, barato, ótimo tool calling).
# Pra trocar: lista em https://openrouter.ai/models — qualquer modelo com tool calling serve.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_REFERER=https://crm21go.site
OPENROUTER_APP_TITLE=21Go CRM

# ============================================================================
# API Brasil (consulta placa + FIPE)
# ============================================================================
# Obter token em: https://app.apibrasil.io
# Custo: R$ 0,10 por consulta (cache evita re-consultas)
APIBRASIL_TOKEN=eyJ0eXAiOiJKV1Q...

# ============================================================================
# LOGGING & SECURITY
# ============================================================================

LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# WEBHOOK — Lead Aprovado
# ============================================================================
# Disparado quando um card entra na fase "APROVADO" do funil "Vendas de Associados".
# Envia payload completo: card + lead (nome, telefone, email, origem, UTMs, gclid, fbclid) + pipe + phase + vendedor.
# Fire-and-forget com 3 tentativas (backoff 1s/3s/9s) e timeout de 10s.
# URL é obrigatória pra ativar o disparo — sem ela, nada é enviado.
WEBHOOK_LEAD_APPROVED_URL=
# Token enviado no header "Authorization: Bearer <token>" (opcional mas recomendado).
# Gere com: openssl rand -hex 32
WEBHOOK_LEAD_APPROVED_TOKEN=
# Nomes do funil e da fase que disparam o webhook (case-insensitive).
# Mude aqui se renomear o funil ou a fase no Kanban.
WEBHOOK_LEAD_APPROVED_PIPE_NAME=Vendas de Associados
WEBHOOK_LEAD_APPROVED_PHASE_NAME=APROVADO

# ==========================================================================
# SGA Hinova (API V2) + Power CRM — SOMENTE LEITURA
# Usado pela rede multinivel (Minha Rede) para contar placas por consultor.
# Doc oficial do SGA: https://api.hinova.com.br/api/sga/v2/doc/
# ==========================================================================
HINOVA_SGA_BASE_URL=https://api.hinova.com.br/api/sga/v2
HINOVA_SGA_TOKEN=            # token de integracao (header do /usuario/autenticar) — nao expira
HINOVA_SGA_USUARIO=
HINOVA_SGA_SENHA=
HINOVA_SGA_CODIGO_CLIENTE=
POWER_TOKEN_API=             # Bearer da API publica do Power — nao expira
POWER_API_BASE_URL=https://api.powercrm.com.br
POWER_APP_BASE_URL=https://app.powercrm.com.br
POWER_APP_BEARER=            # Bearer de SESSAO do painel — EXPIRA em ~10h, renovar via F12
