{
  "name": "crm-21go",
  "version": "1.0.0",
  "private": true,
  "description": "CRM 21Go - Protecao Veicular",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npx tsx src/server.ts",
    "dev:frontend": "cd frontend && npx vite",
    "dev:mock": "cd backend && npx tsx src/server.mock.ts",
    "build": "cd frontend && npm run build && cd ../backend && (npx prisma generate || true) && npx tsup",
    "start": "cd backend && node dist/server.mock.js",
    "postinstall": "cd backend && npx prisma generate || true"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/pg": "^8.10.9",
    "@vercel/node": "^3.0.17",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
